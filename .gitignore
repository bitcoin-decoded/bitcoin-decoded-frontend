# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Claude Code — ignore everything except the shared project skills
# (use `.claude/*` rather than `.claude/` so the `!skills/` exception
# can re-include subpaths — trailing-slash patterns swallow the dir
# itself and block any negation inside).
.claude/*
!.claude/skills/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
